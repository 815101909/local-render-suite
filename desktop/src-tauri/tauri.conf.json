{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Local Render Station",
  "version": "0.1.0",
  "identifier": "com.factory.localrenderstation",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Local Render Station",
        "width": 1480,
        "height": 920,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
